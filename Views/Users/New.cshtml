@model NewUserFormModel
@{
    ViewData["Title"] = "New User";
}

<div class="container">
    <h1>New User</h1>
    <p class="text-muted">Create a user account using the dedicated NewUser script form.</p>

    <div class="card mt-4">
        <div class="card-body">
            <form asp-controller="Users" asp-action="New" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <h5 class="mb-3">Identity</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="FirstName" class="form-label"></label>
                        <input asp-for="FirstName" class="form-control" id="FirstName" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="LastName" class="form-label"></label>
                        <input asp-for="LastName" class="form-control" id="LastName" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="DisplayName" class="form-label"></label>
                        <input asp-for="DisplayName" class="form-control" id="DisplayName" />
                        <span asp-validation-for="DisplayName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="UserPrincipalName" class="form-label"></label>
                        <input asp-for="UserPrincipalName" class="form-control" id="UserPrincipalName" />
                        <span asp-validation-for="UserPrincipalName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SamAccountName" class="form-label"></label>
                        <input asp-for="SamAccountName" class="form-control" />
                        <span asp-validation-for="SamAccountName" class="text-danger"></span>
                    </div>
                </div>

                <h5 class="mt-4 mb-3">Address</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Office" class="form-label"></label>
                        <input asp-for="Office" class="form-control" />
                        <span asp-validation-for="Office" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="StreetAddress" class="form-label"></label>
                        <input asp-for="StreetAddress" class="form-control" />
                        <span asp-validation-for="StreetAddress" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="POBox" class="form-label"></label>
                        <input asp-for="POBox" class="form-control" />
                        <span asp-validation-for="POBox" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="PostalCode" class="form-label"></label>
                        <input asp-for="PostalCode" class="form-control" />
                        <span asp-validation-for="PostalCode" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Country" class="form-label"></label>
                        <input asp-for="Country" class="form-control" />
                        <span asp-validation-for="Country" class="text-danger"></span>
                    </div>
                </div>

                <h5 class="mt-4 mb-3">Organisation</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="JobTitle" class="form-label"></label>
                        <input asp-for="JobTitle" class="form-control" />
                        <span asp-validation-for="JobTitle" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Department" class="form-label"></label>
                        <input asp-for="Department" class="form-control" />
                        <span asp-validation-for="Department" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Company" class="form-label"></label>
                        <input asp-for="Company" class="form-control" />
                        <span asp-validation-for="Company" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Manager" class="form-label"></label>
                        <input asp-for="Manager" class="form-control" placeholder="SAM account name (e.g. AB123)" />
                        <span asp-validation-for="Manager" class="text-danger"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary mt-4">Create User</button>
            </form>
        </div>
    </div>

    @if (Model.ExecutionSucceeded.HasValue)
    {
        <div class="card mt-4">
            <div class="card-header">Execution Result</div>
            <div class="card-body">
                @if (Model.ExecutionSucceeded.Value)
                {
                    <div class="alert alert-success" role="alert">User creation script completed successfully.</div>
                }
                else
                {
                    <div class="alert alert-danger" role="alert">
                        @(string.IsNullOrWhiteSpace(Model.ExecutionError) ? "User creation script failed." : Model.ExecutionError)
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.ExecutionOutput))
                {
                    <pre class="mb-0" style="white-space: pre-wrap; word-wrap: break-word;">@Model.ExecutionOutput</pre>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const firstName = document.getElementById('FirstName');
            const lastName  = document.getElementById('LastName');
            const displayName = document.getElementById('DisplayName');
            const upn       = document.getElementById('UserPrincipalName');

            let displayNameTouched = displayName.value.trim() !== '';
            let upnTouched         = upn.value.trim() !== '';

            displayName.addEventListener('input', () => { displayNameTouched = true; });
            upn.addEventListener('input',         () => { upnTouched = true; });

            function sanitise(val) {
                return val.trim().toLowerCase().replace(/[^a-z0-9]/g, '');
            }

            function update() {
                const first = firstName.value.trim();
                const last  = lastName.value.trim();

                if (!displayNameTouched) {
                    displayName.value = (first + (first && last ? ' ' : '') + last);
                }

                if (!upnTouched) {
                    const f = sanitise(first);
                    const l = sanitise(last);
                    upn.value = (f && l) ? f + '.' + l + '@@cambridgeshire.gov.uk' : '';
                }
            }

            firstName.addEventListener('input', update);
            lastName.addEventListener('input',  update);
        })();
    </script>
}
