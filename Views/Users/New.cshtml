@model NewUserFormModel
@{
    ViewData["Title"] = "New User";
}

<div class="container">
    <h1>New User</h1>
    <p class="text-muted">Create a user account using the dedicated NewUser script form.</p>

    <div class="card mt-4">
        <div class="card-body">
            <form id="scriptForm" asp-controller="Users" asp-action="New" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <h5 class="mb-3">Identity</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="FirstName" class="form-label"></label>
                        <input asp-for="FirstName" class="form-control" id="FirstName" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="LastName" class="form-label"></label>
                        <input asp-for="LastName" class="form-control" id="LastName" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="DisplayName" class="form-label"></label>
                        <input asp-for="DisplayName" class="form-control" id="DisplayName" />
                        <span asp-validation-for="DisplayName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="UserPrincipalName" class="form-label"></label>
                        <input asp-for="UserPrincipalName" class="form-control" id="UserPrincipalName" />
                        <span asp-validation-for="UserPrincipalName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SamAccountName" class="form-label"></label>
                        <input asp-for="SamAccountName" class="form-control" />
                        <span asp-validation-for="SamAccountName" class="text-danger"></span>
                    </div>
                </div>

                <h5 class="mt-4 mb-3">Address</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Office" class="form-label"></label>
                        <input asp-for="Office" class="form-control" />
                        <span asp-validation-for="Office" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="StreetAddress" class="form-label"></label>
                        <input asp-for="StreetAddress" class="form-control" />
                        <span asp-validation-for="StreetAddress" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="POBox" class="form-label"></label>
                        <input asp-for="POBox" class="form-control" />
                        <span asp-validation-for="POBox" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="PostalCode" class="form-label"></label>
                        <input asp-for="PostalCode" class="form-control" />
                        <span asp-validation-for="PostalCode" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Country" class="form-label"></label>
                        <input asp-for="Country" class="form-control" />
                        <span asp-validation-for="Country" class="text-danger"></span>
                    </div>
                </div>

                <h5 class="mt-4 mb-3">Organisation</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="JobTitle" class="form-label"></label>
                        <input asp-for="JobTitle" class="form-control" />
                        <span asp-validation-for="JobTitle" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Department" class="form-label"></label>
                        <input asp-for="Department" class="form-control" />
                        <span asp-validation-for="Department" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Company" class="form-label"></label>
                        <input asp-for="Company" class="form-control" />
                        <span asp-validation-for="Company" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Manager" class="form-label"></label>
                        <input asp-for="Manager" class="form-control" placeholder="SAM account name (e.g. AB123)" />
                        <span asp-validation-for="Manager" class="text-danger"></span>
                    </div>
                </div>

                <button type="submit" id="runBtn" class="btn btn-primary mt-4">Create User</button>
            </form>
        </div>
    </div>

    <div id="loadingIndicator" class="mt-4" style="display: none;">
        <div class="d-flex align-items-center gap-2 text-secondary">
            <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
            <span>Running script&hellip;</span>
        </div>
    </div>

    <div id="output" class="mt-4" style="display: none;">
        <div class="card">
            <div class="card-header">Output</div>
            <div class="card-body">
                <pre id="outputText" style="white-space: pre-wrap; word-wrap: break-word;"></pre>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('scriptForm').addEventListener('submit', async function (e) {
            e.preventDefault();

            const form = e.target;
            if (!form.reportValidity()) return;

            const inputs = form.querySelectorAll('input');
            const runBtn = document.getElementById('runBtn');
            const loadingIndicator = document.getElementById('loadingIndicator');
            const outputDiv = document.getElementById('output');
            const outputText = document.getElementById('outputText');

            inputs.forEach(input => input.disabled = true);
            runBtn.disabled = true;
            runBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Running…';
            loadingIndicator.style.display = 'block';
            outputDiv.style.display = 'none';
            outputText.textContent = '';
            outputText.className = '';

            const url = new URL('@Url.Action("StreamNew", "Users")', window.location.origin);
            inputs.forEach(input => { if (input.name) url.searchParams.set(input.name, input.value); });

            try {
                const response = await fetch(url.toString(), { method: 'GET' });

                if (!response.ok) {
                    outputDiv.style.display = 'block';
                    outputText.className = 'text-danger';
                    outputText.textContent = `Request failed: ${response.status}`;
                    return;
                }

                outputDiv.style.display = 'block';
                loadingIndicator.style.display = 'none';

                const reader = response.body.getReader();
                const decoder = new TextDecoder();
                let buffer = '';

                while (true) {
                    const { done, value } = await reader.read();
                    if (done) break;

                    buffer += decoder.decode(value, { stream: true });
                    const lines = buffer.split('\n');
                    buffer = lines.pop();

                    for (const line of lines) {
                        if (line.startsWith('data:')) {
                            const payload = JSON.parse(line.slice(5).trim());
                            if (payload.type === 'line') {
                                outputText.className = 'text-success';
                                outputText.textContent += payload.text + '\n';
                            } else if (payload.type === 'error') {
                                outputText.className = 'text-danger';
                                outputText.textContent += payload.text + '\n';
                            } else if (payload.type === 'done' && !payload.success) {
                                if (outputText.textContent === '') {
                                    outputText.className = 'text-danger';
                                    outputText.textContent = payload.error || 'Script failed.';
                                }
                            }
                        }
                    }
                }
            } catch (error) {
                outputDiv.style.display = 'block';
                outputText.className = 'text-danger';
                outputText.textContent = 'Connection error: ' + error.message;
            } finally {
                inputs.forEach(input => input.disabled = false);
                runBtn.disabled = false;
                runBtn.innerHTML = 'Create User';
                loadingIndicator.style.display = 'none';
            }
        });
    </script>

    <script>
        (function () {
            const firstName = document.getElementById('FirstName');
            const lastName  = document.getElementById('LastName');
            const displayName = document.getElementById('DisplayName');
            const upn       = document.getElementById('UserPrincipalName');

            let displayNameTouched = displayName.value.trim() !== '';
            let upnTouched         = upn.value.trim() !== '';

            displayName.addEventListener('input', () => { displayNameTouched = true; });
            upn.addEventListener('input',         () => { upnTouched = true; });

            function sanitise(val) {
                return val.trim().toLowerCase().replace(/[^a-z0-9]/g, '');
            }

            function update() {
                const first = firstName.value.trim();
                const last  = lastName.value.trim();

                if (!displayNameTouched) {
                    displayName.value = (first + (first && last ? ' ' : '') + last);
                }

                if (!upnTouched) {
                    const f = sanitise(first);
                    const l = sanitise(last);
                    upn.value = (f && l) ? f + '.' + l + '@@cambridgeshire.gov.uk' : '';
                }
            }

            firstName.addEventListener('input', update);
            lastName.addEventListener('input',  update);
        })();
    </script>
}
