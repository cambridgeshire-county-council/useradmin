@model DeletionSearchViewModel
@{
    ViewData["Title"] = "Mark for Deletion";
}

<div class="container">
    <h1>Mark for Deletion</h1>
    <p class="text-muted">Search for AD accounts and mark or unmark them for deletion.</p>

    <div class="card mt-4">
        <div class="card-body">
            <form asp-controller="Users" asp-action="MarkForDeletion" method="post" class="row g-3">
                @Html.AntiForgeryToken()

                <div class="col-md-9">
                    <label asp-for="Search" class="form-label">Search</label>
                    <input asp-for="Search" class="form-control" placeholder="Enter full or partial name" />
                </div>

                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Search</button>
                </div>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success mt-4" role="alert">@Model.StatusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.Error))
    {
        <div class="alert alert-danger mt-4" role="alert">@Model.Error</div>
    }

    @if (Model.Results.Count > 0)
    {
        <div class="card mt-4">
            <div class="card-header">Results (@Model.Results.Count)</div>
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>SAM Account</th>
                            <th>UPN</th>
                            <th>Status</th>
                            <th>Marked Date</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var user in Model.Results)
                    {
                        <tr>
                            <td>@user.Name</td>
                            <td>@user.SamAccountName</td>
                            <td>@user.UserPrincipalName</td>
                            <td>@(user.Enabled.HasValue ? (user.Enabled.Value ? "Enabled" : "Disabled") : "Unknown")</td>
                            <td>@(user.IsMarked ? user.ExtensionAttribute2 : "—")</td>
                            <td>
                                @if (user.IsMarked)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-secondary js-deletion-trigger"
                                            data-action="unmark" data-sam="@user.SamAccountName" data-name="@user.Name">Unmark</button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-outline-warning js-deletion-trigger"
                                            data-action="mark" data-sam="@user.SamAccountName" data-name="@user.Name">Mark for Deletion</button>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(Model.Search) && string.IsNullOrWhiteSpace(Model.Error))
    {
        <div class="alert alert-secondary mt-4" role="alert">No users found for "@Model.Search".</div>
    }
</div>

<div class="modal fade" id="deletionNotesModal" tabindex="-1" aria-labelledby="deletionNotesModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <form id="deletionNotesForm" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="samAccountName" id="deletionNotesSam" />
            <input type="hidden" name="returnSearch" value="@Model.Search" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="deletionNotesModalLabel">Mark for Deletion</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p id="deletionNotesUser" class="fw-bold"></p>
                    <label for="deletionNotesText" class="form-label">Telephone Notes</label>
                    <textarea id="deletionNotesText" name="notes" class="form-control" rows="4" disabled></textarea>
                    <div id="deletionNotesLoading" class="form-text">Loading current notes…</div>
                    <div id="deletionNotesError" class="text-danger form-text d-none"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" id="deletionNotesConfirm" class="btn btn-warning" disabled>Confirm</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var modalEl = document.getElementById('deletionNotesModal');
            var modal = new bootstrap.Modal(modalEl);
            var form = document.getElementById('deletionNotesForm');
            var samInput = document.getElementById('deletionNotesSam');
            var textarea = document.getElementById('deletionNotesText');
            var loading = document.getElementById('deletionNotesLoading');
            var errorEl = document.getElementById('deletionNotesError');
            var confirmBtn = document.getElementById('deletionNotesConfirm');
            var titleEl = document.getElementById('deletionNotesModalLabel');
            var userEl = document.getElementById('deletionNotesUser');

            var markUrl = '@Url.Action("MarkUser", "Users")';
            var unmarkUrl = '@Url.Action("UnmarkUser", "Users")';
            var notesUrl = '@Url.Action("GetUserNotes", "Users")';

            document.querySelectorAll('.js-deletion-trigger').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var action = btn.dataset.action;
                    var sam = btn.dataset.sam;
                    var name = btn.dataset.name;

                    form.action = action === 'mark' ? markUrl : unmarkUrl;
                    samInput.value = sam;
                    userEl.textContent = name + ' (' + sam + ')';
                    titleEl.textContent = action === 'mark' ? 'Mark for Deletion' : 'Unmark for Deletion';
                    confirmBtn.textContent = action === 'mark' ? 'Mark for Deletion' : 'Unmark';
                    confirmBtn.classList.remove('btn-warning', 'btn-secondary');
                    confirmBtn.classList.add(action === 'mark' ? 'btn-warning' : 'btn-secondary');

                    textarea.value = '';
                    textarea.disabled = true;
                    confirmBtn.disabled = true;
                    loading.classList.remove('d-none');
                    errorEl.classList.add('d-none');

                    modal.show();

                    fetch(notesUrl + '?samAccountName=' + encodeURIComponent(sam))
                        .then(function (resp) {
                            if (!resp.ok) { throw new Error('Failed to load notes.'); }
                            return resp.json();
                        })
                        .then(function (data) {
                            textarea.value = data.notes || '';
                        })
                        .catch(function () {
                            errorEl.textContent = 'Could not load current notes. You can still enter new notes below.';
                            errorEl.classList.remove('d-none');
                        })
                        .finally(function () {
                            textarea.disabled = false;
                            confirmBtn.disabled = false;
                            loading.classList.add('d-none');
                        });
                });
            });
        })();
    </script>
}
