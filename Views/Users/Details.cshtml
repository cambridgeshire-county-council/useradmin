@model UserDetailsViewModel
@{
    ViewData["Title"] = "User Details";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center">
        <h1>User Details</h1>
        <a asp-controller="Users" asp-action="Search" class="btn btn-outline-secondary">Back to Search</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Error))
    {
        <div class="alert alert-danger mt-4" role="alert">@Model.Error</div>
    }
    else
    {
        <div class="card mt-4">
            <div class="card-header">@Model.DisplayName (@Model.SamAccountName)</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Name</dt>
                    <dd class="col-sm-9">@Model.Name</dd>

                    <dt class="col-sm-3">Given Name</dt>
                    <dd class="col-sm-9">@Model.GivenName</dd>

                    <dt class="col-sm-3">Surname</dt>
                    <dd class="col-sm-9">@Model.Surname</dd>

                    <dt class="col-sm-3">User Principal Name</dt>
                    <dd class="col-sm-9">@Model.UserPrincipalName</dd>

                    <dt class="col-sm-3">Email</dt>
                    <dd class="col-sm-9">@Model.Mail</dd>

                    <dt class="col-sm-3">Description</dt>
                    <dd class="col-sm-9">@Model.Description</dd>

                    <dt class="col-sm-3">Department</dt>
                    <dd class="col-sm-9">@Model.Department</dd>

                    <dt class="col-sm-3">Title</dt>
                    <dd class="col-sm-9">@Model.Title</dd>

                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">@(Model.Enabled.HasValue ? (Model.Enabled.Value ? "Enabled" : "Disabled") : "Unknown")</dd>
                </dl>
            </div>
        </div>
    }
</div>